{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:base"],
  "baseBranches": ["main"],
  "labels": ["dependencies", "automated"],
  "prConcurrentLimit": 5,
  "prHourlyLimit": 2,

  "packageRules": [
    {
      "description": "Auto-merge patch-level Helm updates",
      "matchUpdateTypes": ["patch"],
      "matchDatasources": ["helm"],
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "description": "Group GitHub Actions updates",
      "matchManagers": ["github-actions"],
      "groupName": "github-actions",
      "schedule": ["before 7am"],
      "automerge": true
    }
  ],

  "helm-values": {
    "fileMatch": ["applications/.*/application\\.yaml$"]
  },

  "kubernetes": {
    "fileMatch": ["\\.yaml$"]
  }
}